#!/bin/sh
export PYTHONPATH="/Users/ivanpointer/Source/codex-workscribe/src${PYTHONPATH:+:$PYTHONPATH}"

for candidate in python3 python3.12 python3.11 /usr/local/bin/python3 /opt/homebrew/bin/python3; do
  if command -v "$candidate" >/dev/null 2>&1; then
    if "$candidate" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1; then
      exec "$candidate" -m workscribe "$@"
    fi
  fi
done

echo "workscribe requires Python 3.11+ on PATH" >&2
exit 1
